# --- Database ---
POSTGRES_USER=startend
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=startend
DATABASE_URL=postgresql+asyncpg://startend:CHANGE_ME_TO_A_STRONG_PASSWORD@db:5432/startend

# --- WhatsApp ---
# Adapter: "mock" (no real messages) or "meta" (live WhatsApp via Meta Cloud API)
WHATSAPP_ADAPTER=mock

# Required only when WHATSAPP_ADAPTER=meta
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
