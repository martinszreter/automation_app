# --- Database ---
POSTGRES_USER=startend
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_password
POSTGRES_DB=startend

# Must match the credentials above. "db" is the Docker service name.
DATABASE_URL=postgresql+asyncpg://startend:CHANGE_ME_use_a_strong_password@db:5432/startend

# --- App ---
SECRET_KEY=CHANGE_ME_generate_a_random_string

# --- WhatsApp ---
# "mock" = no real messages sent (safe for testing)
# "meta" = live Meta Cloud API
WHATSAPP_ADAPTER=mock

# Only needed when WHATSAPP_ADAPTER=meta
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
